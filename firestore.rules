rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Basic Auth Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    // Projects: Access is restricted to owners and collaborators
    match /projects/{projectId} {
      function canAccessProject() {
        return isSignedIn() && (
          resource.data.ownerId == request.auth.uid || 
          request.auth.uid in resource.data.collaborators
        );
      }

      allow read: if canAccessProject();
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update: if canAccessProject() && 
                    request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // Messages sub-collection
      match /messages/{messageId} {
        allow read: if canAccessProject();
        allow create: if canAccessProject() && request.resource.data.senderId == request.auth.uid;
        allow update: if canAccessProject(); // Support reactions
        allow delete: if canAccessProject() && resource.data.senderId == request.auth.uid;
      }

      // Typing indicators
      match /typing/{userId} {
        allow read: if canAccessProject();
        allow write: if isSignedIn() && request.auth.uid == userId;
      }

      // Document Presence
      match /doc_presence/{presenceId} {
        allow read: if canAccessProject();
        allow write, delete: if isSignedIn();
      }

      // Documents sub-collection
      match /documents/{docId} {
        allow read: if canAccessProject();
        allow create: if canAccessProject() && request.resource.data.createdBy == request.auth.uid;
        allow update: if canAccessProject();
        allow delete: if canAccessProject();
      }
    }

    // Activities: Global feed for network transparency
    match /activities/{activityId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
    }

    // Global Community Messages
    match /global_messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.senderId == request.auth.uid;
      allow update: if isSignedIn(); // For reactions
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Direct Conversations
    match /conversations/{convId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participants;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow update: if isSignedIn(); // For reactions
        allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
      }
    }
  }
}
