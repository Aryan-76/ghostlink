rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 1. User Rules
    function isValidUser(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.email is string && data.email.size() <= 100 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             data.role in ['admin', 'user'] &&
             data.status is string &&
             data.avatarUrl is string &&
             data.updatedAt is timestamp &&
             data.keys().hasAll(['userId', 'email', 'displayName', 'role', 'status', 'avatarUrl', 'updatedAt']) &&
             data.keys().size() == 7;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) && incoming().role == 'user';
      allow update: if isSignedIn() && userId == request.auth.uid && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'status', 'avatarUrl', 'updatedAt']) &&
                    incoming().updatedAt == request.time;
    }

    // 2. Project Rules
    function isValidProject(data) {
      return data.title is string && data.title.size() <= 100 &&
             data.status in ['active', 'planned', 'archived', 'completed'] &&
             data.ownerId is string &&
             data.members is list && data.members.size() <= 20 &&
             data.keys().hasAll(['title', 'status', 'ownerId', 'members']) &&
             data.keys().size() >= 4;
    }

    match /projects/{projectId} {
      allow get: if isSignedIn() && (request.auth.uid == existing().ownerId || request.auth.uid in existing().members || isAdmin());
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.members);
      
      allow create: if isEmailVerified() && isValidId(projectId) && isValidProject(incoming()) && 
                    incoming().createdAt == request.time && incoming().ownerId == request.auth.uid;
      
      allow update: if isSignedIn() && isValidProject(incoming()) && (
        (existing().status != 'completed' && existing().status != 'archived' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'members', 'status', 'updatedAt'])) ||
        isAdmin()
      ) && incoming().updatedAt == request.time && incoming().ownerId == existing().ownerId;

      allow delete: if isAdmin() || (isSignedIn() && existing().ownerId == request.auth.uid);
    }

    // 3. Activity Rules (Top-level for unified feed)
    function isValidActivity(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.type in ['edit', 'comment', 'complete', 'alert'] &&
             data.userId == request.auth.uid &&
             data.timestamp == request.time &&
             data.keys().hasAll(['title', 'type', 'userId', 'timestamp']) &&
             data.keys().size() == 4;
    }

    match /activities/{activityId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isEmailVerified() && isValidId(activityId) && isValidActivity(incoming());
    }

    // 4. Chat Rules
    function isValidMessage(data) {
      return data.text is string && data.text.size() <= 2000 &&
             data.userId in [request.auth.uid, 'ghost-assistant'] &&
             data.userDisplayName is string && data.userDisplayName.size() <= 100 &&
             data.isAI is bool &&
             data.timestamp == request.time &&
             data.keys().hasAll(['text', 'userId', 'userDisplayName', 'isAI', 'timestamp']) &&
             data.keys().size() == 5;
    }

    match /chat/messages/entries/{messageId} {
      // Global chat list: enforce signed in check at rule level
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isEmailVerified() && isValidId(messageId) && isValidMessage(incoming());
    }
  }
}
